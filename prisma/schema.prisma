generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  password       String
  role           String    @default("CLIENT") // ADMIN, AM, MARKETING_MANAGER, CLIENT
  firstName      String
  lastName       String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // ClickUp Integration
  clickupToken   String?
  clickupTeamId  String?

  // HR Fields
  hireDate       DateTime?
  birthday       DateTime?
  phone          String?
  department     String?
  contractType   String?   // FULL_TIME, PART_TIME, FREELANCE, INTERN
  salary         Int?

  // Relations
  clients        Client[]  @relation("AccountManagerClients")
  mmClients      Client[]  @relation("MarketingManagerClients")
  clientProfile  Client?   @relation("ClientUser")
  comments       Comment[]
  sentMessages   Message[]      @relation("SentMessages")
  receivedMessages Message[]   @relation("ReceivedMessages")
  notifications  Notification[]
  activityLogs   ActivityLog[]
  deletionRequests DeletionRequest[]
  contentItemHistory ContentItemHistory[]
  aiConversations    AiConversation[]
  socialConnections  SocialConnection[]
  sentTasks          InternalTask[]    @relation("SentTasks")
  receivedTasks      InternalTask[]    @relation("ReceivedTasks")
  presence           UserPresence?
  roomSession        RoomSession?
  roomMessages       RoomChatMessage[]
  sentSignals        WebRTCSignal[]    @relation("SentSignals")
  receivedSignals    WebRTCSignal[]    @relation("ReceivedSignals")

  // HR relations
  leaveRequests      LeaveRequest[]    @relation("EmployeeLeaves")
  reviewedLeaves     LeaveRequest[]    @relation("ReviewedLeaves")
  performanceReviews PerformanceReview[] @relation("EmployeeReviews")
  authoredReviews    PerformanceReview[] @relation("AuthoredReviews")
  hrNotes            HRNote[]          @relation("EmployeeNotes")
  authoredHRNotes    HRNote[]          @relation("AuthoredHRNotes")
  hrAnnouncements    HRAnnouncement[]
}

model RoomSession {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  roomId    String
  joinedAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([roomId])
}

model RoomChatMessage {
  id        String   @id @default(cuid())
  roomId    String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userName  String
  text      String
  createdAt DateTime @default(now())

  @@index([roomId, createdAt])
}

model WebRTCSignal {
  id          String   @id @default(cuid())
  roomId      String
  fromUserId  String
  from        User     @relation("SentSignals", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUserId    String
  to          User     @relation("ReceivedSignals", fields: [toUserId], references: [id], onDelete: Cascade)
  type        String   // "offer" | "answer" | "ice-candidate"
  payload     String
  consumed    Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([toUserId, consumed, createdAt])
  @@index([roomId])
}

model UserPresence {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status      String   @default("ONLINE") // ONLINE, AWAY, MEETING, DND, OFFLINE
  activity    String?  // e.g., "Working on Action Plans"
  activityUrl String?  // e.g., "/am/action-plans/xxx"
  room        String?  @default("Lounge")
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}

model Client {
  id             String    @id @default(cuid())
  name           String
  logoUrl        String?
  industry       String?
  country        String?
  languages      String?   // Array fallback
  
  // New Profile Metadata (Bilingual)
  briefAr        String?
  briefEn        String?
  deliverablesAr String?
  deliverablesEn String?
  
  // Legacy / Fallback
  brief          String?
  deliverables   String?
  
  // Social Links
  facebook       String?
  instagram      String?
  linkedin       String?
  tiktok         String?
  twitter        String?
  youtube        String?
  snapchat       String?
  website        String?
  
  // Relations
  amId           String?
  accountManager User?     @relation("AccountManagerClients", fields: [amId], references: [id])
  
  mmId           String?
  marketingManager User?   @relation("MarketingManagerClients", fields: [mmId], references: [id])

  userId         String?   @unique
  user           User?     @relation("ClientUser", fields: [userId], references: [id], onDelete: Cascade)
  
  package        String?   @default("BASIC") // e.g., "BASIC", "PREMIUM", "ENTERPRISE"
  activeServices String?   // Comma separated list of active platforms for this client
  seoScore       Int?      @default(0)
  monthlyFee     Int?      @default(0) // Monthly retainer fee in SAR
  
  services       Service[]
  serviceRequests ServiceRequest[]
  meetingRequests MeetingRequest[]
  actionPlans    ActionPlan[]
  reports        Report[]
  socialConnections SocialConnection[]
  internalTasks    InternalTask[]
  ratings        ClientRating[]
  insights       ClientInsight[]

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// ... rest of schema ...

model SocialConnection {
  id                String   @id @default(cuid())
  clientId          String?
  client            Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  platform          String   // "FACEBOOK", "TIKTOK", etc.
  platformAccountId String?  // ID of the page/ad-account on the platform
  platformAccountName String?
  
  accessToken       String
  refreshToken      String?
  expiresAt         DateTime?
  
  isActive          Boolean  @default(true)
  metadata          String?  // JSON string for extra data (scopes, etc)
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([userId, platform, platformAccountId])
}

model MeetingRequest {
  id              String         @id @default(cuid())
  clientId        String
  client          Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  reason          String
  teams           String         // Comma separated list of required teams
  status          String         @default("PENDING") // PENDING, COMPLETED, CANCELLED
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model GlobalService {
  id             String    @id @default(cuid())
  nameAr         String
  nameEn         String
  descriptionAr  String?
  descriptionEn  String?
  icon           String?   // Lucide icon name
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  
  clients        Service[]
  requests       ServiceRequest[]
}

model Service {
  id              String         @id @default(cuid())
  clientId        String
  client          Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  globalServiceId String
  globalService   GlobalService  @relation(fields: [globalServiceId], references: [id], onDelete: Cascade)
  
  assignedAt      DateTime       @default(now())
  
  @@unique([clientId, globalServiceId])
}

model ServiceRequest {
  id              String         @id @default(cuid())
  clientId        String
  client          Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  globalServiceId String
  globalService   GlobalService  @relation(fields: [globalServiceId], references: [id], onDelete: Cascade)
  status          String         @default("PENDING") // PENDING, APPROVED, REJECTED
  notes           String?
  adminNotes      String?
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model ActionPlan {
  id             String    @id @default(cuid())
  clientId       String
  client         Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  month          String    // e.g., "2026-03"
  status         String    @default("DRAFT") // DRAFT, PENDING, APPROVED, REVISION_REQUESTED, SCHEDULED
  mmStatus       String    @default("DRAFT") // DRAFT, PENDING, APPROVED, REJECTED
  
  items          ContentItem[]
  
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model ContentItem {
  id             String      @id @default(cuid())
  planId         String
  plan           ActionPlan  @relation(fields: [planId], references: [id], onDelete: Cascade)
  type           String      // Type enum fallback
  status         String      @default("DRAFT") // Status enum fallback
  
  // Common
  platform       String?     // "Facebook", "Instagram", etc.
  scheduledDate  DateTime?
  
  // Content specifics
  imageUrl       String?
  videoUrl       String?
  captionAr      String?
  captionEn      String?
  
  // Poll
  pollQuestion   String?
  pollOptionA    String?
  pollOptionB    String?
  
  // Article
  articleTitle   String?
  articleContent String?
  keywords       String?     // Array fallback
  
  // Email Marketing
  emailSubject   String?
  emailBody      String?
  emailDesign    String?     // URL or base design reference
  
  // Per-platform captions (JSON string: { "Facebook": "caption text", ... })
  platformCaptions String?
  
  clientComment  String?
  amComment      String?
  feedbackResolved Boolean @default(false)

  // ClickUp Integration
  clickupTaskUrl String?   // Optional link to a related ClickUp task

  comments       Comment[]
  history        ContentItemHistory[]
  
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model ContentItemHistory {
  id             String      @id @default(cuid())
  itemId         String
  item           ContentItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  changedById    String
  changedBy      User        @relation(fields: [changedById], references: [id])
  changeSummary  String?     // e.g., "Updated caption and image"
  
  createdAt      DateTime    @default(now())
}

model Comment {
  id             String      @id @default(cuid())
  itemId         String
  item           ContentItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  userId         String
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  text           String
  
  createdAt      DateTime  @default(now())
}

model Report {
  id             String    @id @default(cuid())
  clientId       String
  client         Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  month          String
  
  // Stored as String for SQLite
  metrics        String      
  status         String    @default("DRAFT") // DRAFT, SENT, VIEWED
  mmStatus       String    @default("DRAFT") // DRAFT, PENDING, APPROVED, REJECTED
  scheduledSendAt DateTime? // If set, auto-publish on this date
  clientFeedback  String?   // Client's feedback text
  clientFeedbackAt DateTime? // When the client submitted feedback
  
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Notification {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id])
  title          String
  message        String
  type           String?   // e.g., "REMINDER", "SYSTEM", "CHAT", "PLAN_READY"
  isRead         Boolean   @default(false)
  link           String?
  
  createdAt      DateTime  @default(now())
}

model Message {
  id             String    @id @default(cuid())
  senderId       String
  sender         User      @relation("SentMessages", fields: [senderId], references: [id])
  receiverId     String
  receiver       User      @relation("ReceivedMessages", fields: [receiverId], references: [id])
  text           String
  isRead         Boolean   @default(false)
  
  createdAt      DateTime  @default(now())
}

model ActivityLog {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id])
  action         String    // e.g., "created Action Plan"
  entityType     String    // e.g., "ActionPlan"
  entityId       String
  
  createdAt      DateTime  @default(now())
}

model DeletionRequest {
  id             String    @id @default(cuid())
  entityType     String    // "Report" or "ActionPlan"
  entityId       String
  status         String    @default("PENDING") // PENDING, APPROVED, REJECTED
  requestedById  String
  requestedBy    User      @relation(fields: [requestedById], references: [id])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model AiConversation {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  messages  AiMessage[]
}

model AiMessage {
  id             String         @id @default(cuid())
  conversationId String
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String
  toolCalls      String?
  createdAt      DateTime       @default(now())
}

model InternalTask {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  type        String   // NEW_TASK, NEED_APPROVAL, ANNOUNCEMENT
  status      String   @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, NEED_FIX

  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  senderId    String
  sender      User     @relation("SentTasks", fields: [senderId], references: [id])

  receiverId  String
  receiver    User     @relation("ReceivedTasks", fields: [receiverId], references: [id])

  feedback    String?  @db.Text

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([clientId])
  @@index([senderId])
  @@index([receiverId])
}

// ─── HR System ────────────────────────────────────────────────────────────────

model LeaveRequest {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation("EmployeeLeaves", fields: [userId], references: [id], onDelete: Cascade)
  type         String   // VACATION, SICK, PERSONAL, EMERGENCY
  startDate    DateTime
  endDate      DateTime
  days         Int
  reason       String?
  status       String   @default("PENDING") // PENDING, APPROVED, REJECTED
  reviewedById String?
  reviewedBy   User?    @relation("ReviewedLeaves", fields: [reviewedById], references: [id])
  reviewNote   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model PerformanceReview {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation("EmployeeReviews", fields: [userId], references: [id], onDelete: Cascade)
  reviewerId   String
  reviewer     User     @relation("AuthoredReviews", fields: [reviewerId], references: [id])
  period       String   // e.g. "2024-Q4"
  score        Int      // 1-5
  strengths    String?  @db.Text
  improvements String?  @db.Text
  goals        String?  @db.Text
  notes        String?  @db.Text
  createdAt    DateTime @default(now())

  @@index([userId])
}

model HRNote {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("EmployeeNotes", fields: [userId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation("AuthoredHRNotes", fields: [authorId], references: [id])
  content   String   @db.Text
  createdAt DateTime @default(now())

  @@index([userId])
}

model HRAnnouncement {
  id          String   @id @default(cuid())
  title       String
  content     String   @db.Text
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  targetRoles String   @default("ALL") // "ALL" or comma-sep roles
  createdAt   DateTime @default(now())
}

model ClientRating {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  month     String   // e.g. "2026-03" — one rating per client per month
  stars     Int      // 1-5
  feedback  String?  @db.Text
  createdAt DateTime @default(now())

  @@unique([clientId, month])
}

model ClientInsight {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type      String   // INDUSTRY | TRENDING | COMPETITORS
  content   String   @db.Text  // JSON array
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@unique([clientId, type])
}
